# ============================================================
# POLYMARKET BOT — ENVIRONMENT CONFIGURATION
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Wallet (Polygon) ---
PRIVATE_KEY=0xyour_polygon_private_key_here
WALLET_ADDRESS=0xyour_wallet_address_here

# --- Polymarket CLOB API ---
CLOB_API_KEY=your_clob_api_key
CLOB_SECRET=your_clob_secret
CLOB_PASSPHRASE=your_clob_passphrase
CLOB_HOST=https://clob.polymarket.com
GAMMA_API=https://gamma-api.polymarket.com

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Capital & Risk ---
STARTING_CAPITAL=10.0           # USD
MAX_RISK_PER_TRADE_PCT=0.08     # 8% of current balance per trade
MAX_DAILY_LOSS_PCT=0.15         # 15% daily loss → pause
DRAWDOWN_CIRCUIT_BREAKER=0.25   # 25% total drawdown → emergency stop
MAX_CAPITAL_DEPLOYED_PCT=0.35   # 35% max capital in positions at once
MIN_EDGE_THRESHOLD=0.75         # Only take trades with ≥75% estimated edge
PROFIT_PARTIAL_EXIT_PCT=0.45    # Exit 45% of position at +30% profit

# --- Strategy Weights ---
ARB_WEIGHT=0.65                 # 65% capital for arb
COPY_WEIGHT=0.25                # 25% capital for copy trading
SIGNAL_WEIGHT=0.10              # 10% capital for signal-based

# --- Copy Trading ---
MIN_WALLET_WIN_RATE=0.70        # Minimum 70% win rate to copy
MIN_WALLET_TRADES=30            # Minimum 30 trades history
MAX_WALLET_DRAWDOWN=0.20        # Skip wallets with >20% drawdown
MAX_WALLETS_TO_TRACK=5          # Track top 5 wallets

# --- Arb Detection ---
ARB_MAX_SUM=0.97                # YES+NO sum below 0.97 = arb opportunity
ARB_MIN_PROFIT_PCT=0.02         # Minimum 2% profit after fees

# --- Operational ---
MODE=dryrun                     # Options: dryrun | paper | live
LOG_LEVEL=INFO
POLYGON_RPC=https://polygon-rpc.com
IRELAND_OPTIMIZED=true          # Low-latency Dublin deployment tweaks
DASHBOARD_PORT=8765    # Web dashboard (http://localhost:8765)
